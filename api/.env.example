PORT=4000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

MONGO_URL=mongodb://127.0.0.1:27017/vedaai
REDIS_URL=redis://127.0.0.1:6380

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Try a :free model first if you haven't added credits yet, e.g.
#   meta-llama/llama-3.3-70b-instruct:free
#   google/gemini-2.0-flash-exp:free
# Paid models are cheaper than they look — anthropic/claude-haiku-4.5 is ~$0.001 per paper.
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_REFERRER=http://localhost:3000
OPENROUTER_TITLE=VedaAI
# Hard cap on output tokens. 2000 fits the free-credit budget and any typical paper.
OPENROUTER_MAX_TOKENS=2000

# JWT — generate a random 32+ char string for production
JWT_SECRET=dev-only-jwt-secret-veda-ai-CHANGE-ME
JWT_EXPIRES_IN=30d

# Set to "stub" to bypass the LLM (useful when no key is set).
LLM_MODE=auto
