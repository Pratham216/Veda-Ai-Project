{
  "name": "vedaai-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/workers/generate.ts",
    "dev:all": "concurrently -k -n api,worker -c blue,magenta \"npm:dev\" \"npm:worker\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:worker": "node dist/workers/generate.js",
    "start:all": "concurrently -k -n api,worker -c blue,magenta \"node dist/index.js\" \"node dist/workers/generate.js\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "openai": "^4.77.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
